</head>
<body>
    <div class="container">

        <div class="note">
<h2>VTU CGPA Calculator 2023</h2>
<p>Click here to know your CGPA of your semesters using our VTU CGPA Calculator. Accurately computing your SGPA/CGPA at Visvesvaraya Technological University (VTU) holds significant importance for every student. Despite the abundance of online calculators, many fall short in providing transparency. Enter the marks properly and get the accurate results.</p>
            <p><strong>Kindly adhere to the outlined steps prior to computing the Cumulative Grade Point Average (CGPA):</strong></p>
            <ol>
                <li>Please input the <b>number of semesters</b> for which you intend to calculate the <b>CGPA</b></li><br>
                <li>Please enter the number of subjects, excluding the subject in which you have failed during the semester exam. 
                    <b>It&#8217;s important to note that failed subjects are considered <b>zero </b> in CGPA calculations</b>
                </li><br>
                <li>If you successfully pass the subject in the subsequent semester, you may include the marks and assigned credits for that subject when counting the total number of subjects in that semester.</li><br>
                <li>Enter the <b>marks</b> and <b>credits assigned</b> for each subjects.</li><br>
                
                <li>Click <b>&#8216;Calculate CGPA&#8217;</b> once you have finished.</li><br>
            </ol>
        </div>

        <h3>VTU CGPA Calculator 2018 scheme/2021 scheme</h3>
        <form id="cgpaForm">
            <label for="totalSemesters">Enter the number of Semesters:</label><br>
            <input type="number" id="totalSemesters" class="semesterInput" placeholder="Enter the number of semesters" required /><br><br>

            <button type="button" class="nextButton" onclick="askSubjects()">Next</button><br>
        </form><br>

        <div id="subjectsForm" style="display:none;">
            <form id="subjectsPerSemesterForm">
                <!-- Content will be dynamically added here -->
            </form><br>

            <button type="button" onclick="askMarksAndCredit()">Next</button><br>
        </div><br>

        <div id="marksForm" style="display:none;">
            <form id="marksAndCreditForm">
                <!-- Content will be dynamically added here -->
            </form><br>

            <button type="button" onclick="calculateCGPA()">Calculate CGPA</button><br>
        </div>

        <div id="result" style="display:none; margin-top: 20px;">
            <h3>CGPA Result:</h3>
            <p id="cgpaOutput"></p>
        </div>
    </div>

    <script>
        function askSubjects() {
            const totalSemesters = parseInt(document.getElementById('totalSemesters').value);
            const subjectsForm = document.getElementById('subjectsPerSemesterForm');

            for (let semester = 1; semester <= totalSemesters; semester++) {
                const label = document.createElement('label');
                label.textContent = `Number of subjects in Semester ${semester}:`;

                const input = document.createElement('input');
                input.type = 'number';
                input.name = `subjectsSemester${semester}`;
                input.required = true;

                subjectsForm.appendChild(label);
                subjectsForm.appendChild(input);
            }

            document.getElementById('subjectsForm').style.display = 'block';
        }

        function askMarksAndCredit() {
            const totalSemesters = parseInt(document.getElementById('totalSemesters').value);
            const marksForm = document.getElementById('marksAndCreditForm');

            for (let semester = 1; semester <= totalSemesters; semester++) {
                const subjectsPerSemester = parseInt(document.querySelector(`[name="subjectsSemester${semester}"]`).value);

                for (let subject = 1; subject <= subjectsPerSemester; subject++) {
                    const marksLabel = document.createElement('label');
                    marksLabel.textContent = `Enter marks for Semester ${semester}, Subject ${subject}:`;

                    const marksInput = document.createElement('input');
                    marksInput.type = 'number';
                    marksInput.name = `marksSemester${semester}Subject${subject}`;
                    marksInput.required = true;

                    const creditLabel = document.createElement('label');
                    creditLabel.textContent = `Enter credit assigned for Semester ${semester}, Subject ${subject}:`;

                    const creditInput = document.createElement('input');
                    creditInput.type = 'number';
                    creditInput.name = `creditSemester${semester}Subject${subject}`;
                    creditInput.required = true;

                    marksForm.appendChild(marksLabel);
                    marksForm.appendChild(marksInput);
                    marksForm.appendChild(creditLabel);
                    marksForm.appendChild(creditInput);
                }
            }

            document.getElementById('marksForm').style.display = 'block';
        }

        function calculateCGPA() {
            const totalSemesters = parseInt(document.getElementById('totalSemesters').value);
            let totalMarks = 0;
            let totalCredit = 0;

            for (let semester = 1; semester <= totalSemesters; semester++) {
                const subjectsPerSemester = parseInt(document.querySelector(`[name="subjectsSemester${semester}"]`).value);

                for (let subject = 1; subject <= subjectsPerSemester; subject++) {
                    const marks = parseInt(document.querySelector(`[name="marksSemester${semester}Subject${subject}"]`).value);
                    const creditAssigned = parseInt(document.querySelector(`[name="creditSemester${semester}Subject${subject}"]`).value);

                    let grade, gradePoint;

                    if (marks >= 90) {
                        grade = 'S';
                        gradePoint = 10;
                    } else if (marks >= 80) {
                        grade = 'A';
                        gradePoint = 9;
                    } else if (marks >= 70) {
                        grade = 'B';
                        gradePoint = 8;
                    } else if (marks >= 60) {
                        grade = 'C';
                        gradePoint = 7;
                    } else if (marks >= 45) {
                        grade = 'D';
                        gradePoint = 6;
                    } else if (marks >= 40) {
                        grade = 'E';
                        gradePoint = 5;
                    } else {
                        grade = 'F';
                        gradePoint = 0;
                    }

                    const mark1 = creditAssigned * gradePoint;
                    totalMarks += mark1;
                    totalCredit += creditAssigned;
                }
            }

            const cgpa = (totalMarks / totalCredit).toFixed(2);

            document.getElementById('result').style.display = 'block';
            document.getElementById('cgpaOutput').innerText = `Your CGPA is: ${cgpa}`;
        }
    </script>
</body>
</html>



